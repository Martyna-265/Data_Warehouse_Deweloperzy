    <DTS:Executable
      DTS:refId="Package\Zasilanie FaktMieszkania"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{EC8BADA4-16F6-4733-9167-6C3DAB985BA1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilanie FaktMieszkania"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="DELETE FROM FaktMieszkania;&#xA;DBCC CHECKIDENT ('FaktMieszkania', RESEED, 0);&#xA;&#xA;WITH SkonsolidowanyStaging AS (&#xA;    SELECT &#xA;        Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa,&#xA;        MAX(CASE WHEN Zrodlo = 'Liczba' THEN Wartosc END) AS Liczba,&#xA;        MAX(CASE WHEN Zrodlo = 'Mediana' THEN Wartosc END) AS Mediana,&#xA;        MAX(CASE WHEN Zrodlo = 'Powierzchnia' THEN Wartosc END) AS Powierzchnia,&#xA;        MAX(CASE WHEN Zrodlo = 'SredniaCena' THEN Wartosc END) AS SredniaCena,&#xA;        MAX(CASE WHEN Zrodlo = 'SredniaCenaM2' THEN Wartosc END) AS SredniaCenaM2,&#xA;        MAX(CASE WHEN Zrodlo = 'Wartosc' THEN Wartosc END) AS WartoscMieszkan&#xA;    FROM (&#xA;        SELECT 'Liczba' AS Zrodlo, Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaLiczba&#xA;        UNION ALL&#xA;        SELECT 'Mediana', Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaMediana&#xA;        UNION ALL&#xA;        SELECT 'Powierzchnia', Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaPowierzchnia&#xA;        UNION ALL&#xA;        SELECT 'SredniaCena', Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaSredniaCena&#xA;        UNION ALL&#xA;        SELECT 'SredniaCenaM2', Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaSredniaCenaM2&#xA;        UNION ALL&#xA;        SELECT 'Wartosc', Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa, Wartosc FROM StagingMieszkaniaWartosc&#xA;    ) AS WszystkiePliki&#xA;    GROUP BY Kod, Rok, Okresy, TransakcjeRynkowe, PowierzchniaUzytkowa&#xA;)&#xA;INSERT INTO FaktMieszkania (&#xA;    OkresID, &#xA;    KategoriaMieszkaniaID, &#xA;    RegionID, &#xA;    LiczbaMieszkań, &#xA;    MedianaCenZaM2, &#xA;    PowierzchniaUzytkowa, &#xA;    ŚredniaCena, &#xA;    ŚredniaCenaZaM2, &#xA;    WartośćMieszkań&#xA;)&#xA;SELECT &#xA;    do.OkresID,&#xA;    dk.KategoriaMieszkaniaID,&#xA;    dr.RegionID,&#xA;    ISNULL(TRY_CAST(stg.Liczba AS INT), 0) AS LiczbaMieszkań,&#xA;    ISNULL(TRY_CAST(stg.Mediana AS MONEY), 0) AS MedianaCenZaM2,&#xA;    ISNULL(TRY_CAST(REPLACE(stg.Powierzchnia, ',', '.') AS DECIMAL(18,1)), 0) AS PowierzchniaUzytkowa,&#xA;    ISNULL(TRY_CAST(stg.SredniaCena AS MONEY), 0) AS ŚredniaCena,&#xA;    ISNULL(TRY_CAST(stg.SredniaCenaM2 AS MONEY), 0) AS ŚredniaCenaZaM2,&#xA;    ISNULL(TRY_CAST(stg.WartoscMieszkan AS MONEY), 0) AS WartośćMieszkań&#xA;&#xA;FROM SkonsolidowanyStaging stg&#xA;&#xA;INNER JOIN DimOkres do &#xA;    ON do.Rok = CAST(stg.Rok AS INT) &#xA;    AND do.Kwartał = CAST(LEFT(stg.Okresy, 1) AS INT)&#xA;    AND do.MiesiącNumer = (CAST(LEFT(stg.Okresy, 1) AS INT) * 3)&#xA;&#xA;INNER JOIN DimKategoriaMieszkania dk&#xA;    ON dk.Rynek = stg.TransakcjeRynkowe&#xA;    AND dk.Metraz = stg.PowierzchniaUzytkowa&#xA;&#xA;INNER JOIN DimRegion dr &#xA;    ON dr.KodWojewództwa = CAST(stg.Kod AS INT)&#xA;    AND DATEFROMPARTS(CAST(stg.Rok AS INT), CAST(LEFT(stg.Okresy, 1) AS INT) * 3, 1) &gt;= dr.ValidFrom&#xA;    AND (dr.ValidTo IS NULL OR DATEFROMPARTS(CAST(stg.Rok AS INT), CAST(LEFT(stg.Okresy, 1) AS INT) * 3, 1) &lt; dr.ValidTo);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Zasilanie FaktWynagrodzenieRegion"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{76AB70B7-97E8-4383-902E-83F9E70BD6BB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilanie FaktWynagrodzenieRegion"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="INSERT INTO FaktWynagrodzenieRegion (RegionID, OkresID, Wynagrodzenie)&#xA;SELECT &#xA;    dr.RegionID,&#xA;    do.OkresID,&#xA;    TRY_CAST(stg.Wartosc AS DECIMAL(18,2)) AS Wartosc&#xA;FROM StagingWynagrodzeniaRegion stg&#xA;&#xA;INNER JOIN DimOkres do &#xA;    ON do.Rok = CAST(stg.Rok AS INT) &#xA;    AND do.Kwartał = CAST(LEFT(stg.Okresy, 1) AS INT)&#xA;    AND do.MiesiącNumer = (CAST(LEFT(stg.Okresy, 1) AS INT) * 3)&#xA;&#xA;INNER JOIN DimRegion dr &#xA;    ON dr.KodWojewództwa = CAST(stg.Kod AS INT)&#xA;    AND DATEFROMPARTS(CAST(stg.Rok AS INT), CAST(LEFT(stg.Okresy, 1) AS INT) * 3, 1) &gt;= dr.ValidFrom&#xA;    AND (dr.ValidTo IS NULL OR DATEFROMPARTS(CAST(stg.Rok AS INT), CAST(LEFT(stg.Okresy, 1) AS INT) * 3, 1) &lt; dr.ValidTo)&#xA;&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM FaktWynagrodzenieRegion f&#xA;    WHERE f.RegionID = dr.RegionID&#xA;      AND f.OkresID = do.OkresID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Zasilenie DimJednostka"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{810A3824-54C9-4898-9886-57841FCC9FCF}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilenie DimJednostka"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM DimJednostka WHERE NazwaJednostki = 'zł')&#xA;    INSERT INTO DimJednostka (NazwaJednostki) VALUES ('zł');&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DimJednostka WHERE NazwaJednostki = 'tys.')&#xA;    INSERT INTO DimJednostka (NazwaJednostki) VALUES ('tys.');&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DimJednostka WHERE NazwaJednostki = 'analogiczny okres roku poprzedniego=100')&#xA;    INSERT INTO DimJednostka (NazwaJednostki) VALUES ('analogiczny okres roku poprzedniego=100');&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DimJednostka WHERE NazwaJednostki = 'od początku roku do końca okresu (analogiczny okres roku poprzedniego=100)')&#xA;    INSERT INTO DimJednostka (NazwaJednostki) VALUES ('od początku roku do końca okresu (analogiczny okres roku poprzedniego=100)');&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DimJednostka WHERE NazwaJednostki = 'okres poprzedni=100')&#xA;    INSERT INTO DimJednostka (NazwaJednostki) VALUES ('okres poprzedni=100');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Zasilenie DimKategoriaMieszkania"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E13B73A0-3BDA-4386-BA88-F5B6DCF8ACFC}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilenie DimKategoriaMieszkania"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="IF (SELECT COUNT(*) FROM DimKategoriaMieszkania) = 0&#xA;BEGIN&#xA;    INSERT INTO DimKategoriaMieszkania (Rynek, Metraz)&#xA;    SELECT r.Rynek, m.Metraz&#xA;    FROM &#xA;        (VALUES ('ogółem'), ('rynek pierwotny'), ('rynek wtórny')) AS r(Rynek)&#xA;    CROSS JOIN &#xA;        (VALUES ('ogółem'), ('do 40 m2'), ('od 40,1 do 60 m2'), ('od 60,1 do 80 m2'), ('od 80,1 m2')) AS m(Metraz);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Zasilenie DimOkres"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{33444D81-4F58-4D72-9D44-EC42571417F9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilenie DimOkres"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="DECLARE @StartDate DATE = '2014-01-01';&#xA;DECLARE @EndDate DATE = DATEFROMPARTS(YEAR(GETDATE()), 12, 31); &#xA;DECLARE @CurrentDate DATE = @StartDate;&#xA;DECLARE @CurrentOkresID INT;&#xA;&#xA;WHILE @CurrentDate &lt;= @EndDate&#xA;BEGIN&#xA;    SET @CurrentOkresID = YEAR(@CurrentDate) * 100 + MONTH(@CurrentDate);&#xA;&#xA;    IF NOT EXISTS (SELECT 1 FROM DimOkres WHERE OkresID = @CurrentOkresID)&#xA;    BEGIN&#xA;        INSERT INTO DimOkres (OkresID, Rok, Kwartał, MiesiącNumer, MiesiącNazwa)&#xA;        VALUES (&#xA;            @CurrentOkresID, &#xA;            YEAR(@CurrentDate),&#xA;            CAST(DATENAME(quarter, @CurrentDate) AS INT), &#xA;            MONTH(@CurrentDate),&#xA;            CHOOSE(MONTH(@CurrentDate), 'Styczeń', 'Luty', 'Marzec', 'Kwiecień', 'Maj', 'Czerwiec', 'Lipiec', 'Sierpień', 'Wrzesień', 'Październik', 'Listopad', 'Grudzień')&#xA;        );&#xA;    END&#xA;    &#xA;    SET @CurrentDate = DATEADD(month, 1, @CurrentDate);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
