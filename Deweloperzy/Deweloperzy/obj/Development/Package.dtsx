    <DTS:Executable
      DTS:refId="Package\Zasilenie DimSektor"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{DE92242F-1ED9-4EB6-A302-F9A6D08FCB9A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Zasilenie DimSektor"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F7E9F975-F239-4BCF-8698-044739DAC0A9}"
          SQLTask:SqlStatementSource="IF (SELECT COUNT(*) FROM DimSektor) = 0&#xA;BEGIN&#xA;&#xA;    WITH CzysteDane AS (&#xA;        SELECT &#xA;            REPLACE(NazwaOryginalna, '  ', ' ') AS NazwaOryginalna&#xA;        FROM (&#xA;            VALUES &#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w gospodarce narodowej'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w sferze budżetowej'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w sektorze przedsiębiorstw'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w przemyśle'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w budownictwie'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w handlu'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w transporcie i gospodarce magazynowej'),&#xA;            ('Przeciętne miesięczne wynagrodzenia nominalne brutto w informacji i komunikacji'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w działalności finansowej i ubezpieczeniowej'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w obsłudze rynku nieruchomości'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w edukacji'),&#xA;            ('Przeciętne miesięczne wynagrodzenie nominalne brutto w opiece zdrowotnej i pomocy społecznej'),&#xA;            ('Przeciętne miesięczne wynagrodzenie realne brutto w gospodarce narodowej'),&#xA;            ('Przeciętne miesięczne wynagrodzenie realne brutto w sektorze przedsiębiorstw')&#xA;        ) AS T(NazwaOryginalna)&#xA;    )&#xA;&#xA;    INSERT INTO DimSektor (NazwaOryginalna, NazwaSektora, TypWynagrodzenia)&#xA;    SELECT &#xA;        NazwaOryginalna,&#xA;        &#xA;        LTRIM(RTRIM(&#xA;            CASE &#xA;                WHEN CHARINDEX(' w ', NazwaOryginalna) &gt; 0 THEN SUBSTRING(NazwaOryginalna, CHARINDEX(' w ', NazwaOryginalna) + 3, LEN(NazwaOryginalna))&#xA;                WHEN NazwaOryginalna LIKE 'w %' THEN SUBSTRING(NazwaOryginalna, 3, LEN(NazwaOryginalna))&#xA;                ELSE NazwaOryginalna &#xA;            END&#xA;        )) AS NazwaSektora,&#xA;&#xA;        CASE &#xA;            WHEN NazwaOryginalna LIKE '%realne%' THEN 'Realne'&#xA;            WHEN NazwaOryginalna LIKE '%nominalne%' THEN 'Nominalne'&#xA;            ELSE 'Inne / Brak'&#xA;        END AS TypWynagrodzenia&#xA;    FROM CzysteDane;&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
